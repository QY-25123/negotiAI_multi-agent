# Copy this file to .env and fill in your values

# ── Anthropic ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Database ───────────────────────────────────────────────────────────────
# Leave blank to use local SQLite inside Docker (default, no setup required).
#
# To use Supabase PostgreSQL:
#   1. Create a project at https://supabase.com
#   2. Go to Project Settings → Database → Connection string → URI
#   3. Copy the "Transaction pooler" URI (port 6543) for Docker deployments
#   4. Paste it below (replace [YOUR-PASSWORD] with your DB password)
#
# DATABASE_URL=postgresql://postgres.xxxx:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ── CORS (production) ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (used on AWS backend).
# Example: https://your-app.vercel.app,https://your-custom-domain.com
# CORS_ORIGINS=https://your-app.vercel.app

# ── Auth (local JWT mode) ──────────────────────────────────────────────────
# Secret used to sign/verify local JWTs. Generate with: openssl rand -hex 32
# LOCAL_JWT_SECRET=change-me-in-production

# ── Frontend (set in Vercel dashboard, not this file) ─────────────────────
# NEXT_PUBLIC_API_URL=https://your-backend.amazonaws.com
